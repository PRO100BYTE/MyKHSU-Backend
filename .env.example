# Настройки окружения — скопируйте в .env и заполните
PORT=8080
HOST=0.0.0.0

# Путь к SQLite базам данных
PAIRS_DB_PATH=./data/pairs.sqlite
USERS_DB_PATH=./data/users.sqlite

# JWT секрет (минимум 32 символа, желательно 64)
JWT_SECRET=replace_this_with_a_long_random_string_at_least_64_chars_long_here

# Путь к статическим файлам (если ServeStatic=false — файлы встроены в dist)
STATIC_PATH=./static

# Логирование
LOG_TO_CONSOLE=true
LOG_LEVEL=info

# Дебаг
DEBUG=false

# Путь к исходникам MyKHSU-web (по умолчанию используется сабмодуль ./mykhsu-web)
WEB_SOURCE_PATH=./mykhsu-web
