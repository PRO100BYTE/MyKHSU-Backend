# Copy to: /etc/mykhsu/mykhsu-backend.env
# chmod 600 /etc/mykhsu/mykhsu-backend.env

# Backend app env:
PORT=8080
HOST=0.0.0.0
PAIRS_DB_PATH=/opt/mykhsu/MyKHSU-Backend/data/pairs.sqlite
USERS_DB_PATH=/opt/mykhsu/MyKHSU-Backend/data/users.sqlite
JWT_SECRET=change-this-to-a-strong-random-secret-min-32-chars
LOG_TO_CONSOLE=true
DEBUG=false

# SMTP (optional):
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=mailer@example.com
# SMTP_PASS=your-password
# SMTP_FROM=mailer@example.com

# Auto-update settings used by deploy/systemd/mykhsu-backend-update.sh
MYKHSU_GIT_AUTOUPDATE=1
MYKHSU_GIT_BRANCH=main
MYKHSU_APP_DIR=/opt/mykhsu/MyKHSU-Backend

# Set to 1 only for manual forced update runs
MYKHSU_GIT_FORCE_UPDATE=0
